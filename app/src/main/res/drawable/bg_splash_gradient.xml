<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main Background: Deep Space to Nebula Gray -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#0F0F11"
                android:endColor="#18181B" />
        </shape>
    </item>

    <!-- Center Glow: Soft Lavender with 8% Opacity -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="400dp"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#14C084FC"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>