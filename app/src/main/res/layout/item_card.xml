<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/luxury_purple"
    app:cardBackgroundColor="@color/card_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/app_background"
            android:layout_marginEnd="16dp">

            <ImageView
                android:id="@+id/ivItemIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_calendar"
                app:tint="@color/primary"
                android:contentDescription="Reminder Icon" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvItemContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reminder Content"
                android:textColor="@color/main_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvItemSubtext"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Subtitle/Time"
                android:textColor="@color/subtext_color"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivPriorityIcon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_priority"
            app:tint="#FF3B30"
            android:visibility="gone"
            android:contentDescription="Priority" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>