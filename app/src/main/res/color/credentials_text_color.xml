<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused/Active state: High visibility (White/Luxury Lavender) -->
    <item android:state_focused="true" android:color="@color/white" />
    <item android:state_activated="true" android:color="@color/white" />

    <!-- Inactive state: Subtle visibility (Secondary Text) -->
    <item android:color="@color/secondary_text" />
</selector>
